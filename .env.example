# Copy to .env and fill in (locally). In CI these are GitHub Actions secrets.
# NEVER commit .env.

# Deployment under test (defaults to the FitLog dev site if unset)
BASE_URL=https://fitlog-9wl.pages.dev

# Dedicated E2E test account (Supabase email+password user)
E2E_EMAIL=e2e@fitlog.app
E2E_PASSWORD=

# Supabase REST access for the API specs + test-data cleanup.
# Same URL + anon key the app itself ships to the browser — not privileged.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# OPTIONAL: extra accounts for per-worker isolation. When present, parallel
# Playwright workers round-robin across accounts, so account-global state
# (profile, streak, latest weight) can't collide. Unset = all workers share
# the base account (fully supported).
#E2E_EMAIL_W1=
#E2E_PASSWORD_W1=
#E2E_EMAIL_W2=
#E2E_PASSWORD_W2=
#E2E_EMAIL_W3=
#E2E_PASSWORD_W3=

# CI-only (repository secrets, no local use): the prod canary reads
# PROD_BASE_URL, PROD_E2E_EMAIL, PROD_E2E_PASSWORD, PROD_SUPABASE_URL,
# PROD_SUPABASE_ANON_KEY and runs the read-only @readonly subset against
# production. The FitLog repo's dispatch needs E2E_DISPATCH_TOKEN there.
